# Normaliza fim de linha: o repositorio guarda sempre LF.
# Evita o index.html aparecer "100% modificado" por causa de CRLF/LF.
* text=auto

*.html text
*.css  text
*.js   text
*.sql  text
*.json text
*.md   text
*.svg  text

# Binarios (nao normalizar)
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.webp binary
